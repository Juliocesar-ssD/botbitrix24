# Base do webhook Bitrix24 - APENAS a base, sem o nome do metodo.
# Formato: https://SEUPORTAL.bitrix24.com.br/rest/USUARIO/TOKEN
BITRIX_WEBHOOK_BASE_URL=https://portal.bitrix24.com.br/rest/USUARIO/TOKEN

# Chave exigida no header X-Integration-Key para chamar a API interna.
INTEGRATION_API_KEY=troque-por-uma-chave-forte-e-unica

# Base da API publica da CNPJa (nao exige token).
CNPJA_BASE_URL=https://open.cnpja.com

# Banco local (SQLite assincrono) usado para log e idempotencia.
DATABASE_URL=sqlite+aiosqlite:///./data/cnpj_sync.db

# Timeout (segundos) aplicado a chamadas HTTP externas (Bitrix e CNPJa).
HTTP_TIMEOUT_SECONDS=20

# Limite local de consultas por minuto a API publica da CNPJa.
MAX_CNPJA_REQUESTS_PER_MINUTE=5

# Nivel de log: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Se true, preenche os campos individuais de endereco alem do campo de endereco completo.
FILL_SEPARATE_ADDRESS_FIELDS=true

# Moeda usada ao formatar o campo money (capital social).
BITRIX_CURRENCY=BRL

# Horas de validade de uma sincronizacao para o mesmo deal_id + CNPJ antes de permitir nova consulta sem force=true.
SYNC_TTL_HOURS=24
